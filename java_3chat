import java.util.Scanner;

public class EjercicioArrays {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int[] notas = new int[5];

        System.out.println("Introduce 5 notas:");

        for (int i = 0; i < notas.length; i++) {
            System.out.print("Nota " + (i + 1) + ": ");
            notas[i] = sc.nextInt();
        }

        int media = calcularMedia(notas);
        int mayor = encontrarMayor(notas);
        int menor = encontrarMenor(notas);

        System.out.println("La media es: " + media);
        System.out.println("La nota mayor es: " + mayor);
        System.out.println("La nota menor es: " + menor);

        sc.close();
    }

    // Haz tú estos métodos:
    public static int calcularMedia(int[] notas) {
        int suma = 0;
        int media = 0;
        for (int i = 0; i < notas.length; i++) {
            suma += notas[i] ;
        }
        media = suma / notas.length;
        return media;
    }

    public static int encontrarMayor(int[] notas) {
        int max = -9999;
        int max_num = 0;
        for (int i = 0; i < notas.length; i++) {
            if (notas[i] > max) {
                max = notas[i];
                max_num = max;
            }
            }
           return max_num; 
        }

    public static int encontrarMenor(int[] notas) {
        int min = 99999;
        int min_num = 0;
        for (int i = 0; i < notas.length; i++) {
            if (notas[i] < min) {
                min = notas[i];
                min_num = min;
            }
            
        }
       return min_num; 
    }
}
